	<!-- Add this at the bottom of web.config, ABOVE </configuration> -->
	<location path="Administration/ResetPasswordHelper.aspx">
		<system.web>
			<authorization>
				<allow users="*" />
				<!-- Asterisk means ALL users (including unauthenticated) -->
			</authorization>
		</system.web>
	</location>
	<location path="DisableClient.aspx">
		<system.web>
			<authorization>
				<allow users="*" />
				<!-- Allows all users, but we'll validate using the security token -->
			</authorization>
		</system.web>
	</location>
	<!-- Allow anonymous (token-based) access ONLY to OrderDetail.aspx 1 oct -->
	<location path="Pages/ViewMyOrder.aspx">
		<system.web>
			<authorization>
				<allow users="*" />
			</authorization>
		</system.web>
		<system.webServer>
			<httpProtocol>
				<customHeaders>
					<add name="Cache-Control" value="no-store, no-cache, must-revalidate" />
					<add name="Pragma" value="no-cache" />
					<add name="Expires" value="0" />
				</customHeaders>
			</httpProtocol>
		</system.webServer>
	</location>
