<configuration>
	<appSettings>
		<add key="Version" value="2.1.2.8" />
		<add key="SysEmailFrom" value="orders@quaffee.co.za" />
		<add key="SysCCEmailAddress" value="orders@quaffee.co.za" />
		<add key="EMailLogIn" value="noreply@quaffee.co.za" />
		<add key="EMailPassword" value="Fr3sh-$pec!alty~Qu4ff33" />
		<add key="EMailSMTP" value="smtp.office365.com" />
		<add key="EMailPort" value="587" />
		<add key="EMailSSLEnabled" value="true" />
		<add key="GMailSMTP" value="mail.roastery.co.za" />
		<add key="DefaultDeliveryID" value="6" />
		<!--- new email stuff -->
		<add key="EmailSocketOption" value="StartTls" />
		<add key="EmailTimeout" value="10000" />
		<add key="AppTimeZoneId" value="South Africa Standard Time" />
		<add key="DisableClientSecret" value="FrogQuaffer!IsSad2SayGoodBye.K8mF3nR9" />
		<add key="ApplicationBaseUrl" value="http://localhost:51830/" />
		<!-- Email Test Mode Configuration -->
		<add key="EmailTestMode" value="true" />
		<add key="EmailTestRecipient" value="warren@machanik.com" />
		<add key="EnableDatabaseDetailedLogging" value="false" />
		<add key="EmailDebugSaveMime" value="false" />
		<!-- Cioffe checkup Configurations -->
		<add key="CoffeeCheckupReminderWindowDays" value="9" />
		<add key="CoffeeCheckupReminderWindowMin" value="5" />
		<add key="CoffeeCheckupReminderWindowMax" value="30" />
		<add key="CoffeeCheckupMinMonthlyRecurringDays" value="20" />
		<add key="CoffeeCheckupDateMatrixTTLMinutes" value="10"/>
		<add key="CoffeeCheckupDateMatrixBufferDays" value="5"/>
		<add key="CoffeeCheckupUseSqlMatrix" value="false"/>
		<add key="CoffeeCheckupRebuildIfSourceChanges" value="true"/>
		<!-- Time override for diagnostic date testing -->
		<add key="TestNow.Enabled" value="false" />
		<!-- Accepts: yyyy-MM-dd or yyyy-MM-dd HH:mm:ss or ISO 8601 (e.g. 2025-09-12T08:30:00) -->
		<add key="TestNow.Value" value="2025-10-12" />
		<add key="TestNow.InputKind" value="Local" />
		<!-- how many days ahead must we check if a closure date will force a forward -->
		<add key="HolidayClosureImminentDays" value="4" />
		<!-- view order changes -->
		<add key="RequestChanges.NotifyEmail" value="true" />
		<!-- Migration: disable legacy Access usage; set to true to force-fail any Access path -->
		<add key="DisableAccessDb" value="true" />
	</appSettings>
	<connectionStrings>
		<!-- Intentionally invalidated Access connection string (file name typo) -->
		<add name="Tracker08ConnectionString" connectionString="Provider=Microsoft.ACE.OLEDB.12.0;Data Source=C:\SRC\Data\QuaffeeTracker08.mdbx" providerName="System.Data.OleDb" />
		<add name="TrackerDataSQL" connectionString="Data Source=.\SQLExpress;Initial Catalog=OtterDb;Persist Security Info=True;User ID=sa;Password=5QL!Lilith477#" providerName="System.Data.SqlClient" />
		<add name="ApplicationServices" connectionString="Data Source=.\SQLExpress;Initial Catalog=QOnTSecurity;Persist Security Info=True;User ID=sa;Password=5QL!Lilith477#" providerName="System.Data.SqlClient" />
